{
  "mcpServers": {
    "google-tag-manager": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://gtm-mcp.pragmaticgrowth.com/mcp"]
    },
    "railway": {
      "command": "npx",
      "args": ["-y", "@railway/mcp-server"]
    },
    "time": {
      "command": "uvx",
      "args": ["mcp-server-time"]
    }
  }
}
